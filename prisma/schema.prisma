generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  OWNER
  EDITOR
  VIEWER
}

enum ActionType {
  MOVED
  CREATED
  UPDATED
  DELETED
  ASSIGNED
  UNASSIGNED
}

// ─── Auth (NextAuth v5 / @auth/prisma-adapter) ───────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  boardMembers     BoardMember[]
  assignedCards    CardAssignee[]
  targetActivities Activity[]    @relation("ActivityTarget")
  activities       Activity[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Board ────────────────────────────────────────────────────────────────────

model Board {
  id          String   @id @default(cuid())
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members BoardMember[]
  columns Column[]
  labels  Label[]
}

model BoardMember {
  id        String   @id @default(cuid())
  boardId   String
  userId    String
  role      Role     @default(VIEWER)
  createdAt DateTime @default(now())

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
}

// ─── Column ───────────────────────────────────────────────────────────────────

model Column {
  id        String   @id @default(cuid())
  title     String
  position  Float
  boardId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  board          Board      @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards          Card[]
  fromActivities Activity[] @relation("FromColumn")
  toActivities   Activity[] @relation("ToColumn")
}

// ─── Card ─────────────────────────────────────────────────────────────────────

model Card {
  id          String    @id @default(cuid())
  title       String
  description String?   @db.Text
  position    Float
  dueDate     DateTime?
  columnId    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  column     Column         @relation(fields: [columnId], references: [id], onDelete: Cascade)
  assignees  CardAssignee[]
  labels     CardLabel[]
  activities Activity[]
}

model CardAssignee {
  cardId String
  userId String

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([cardId, userId])
}

// ─── Activity ─────────────────────────────────────────────────────────────────

model Activity {
  id           String     @id @default(cuid())
  action       ActionType
  cardId       String
  userId       String
  fromColumnId String?
  toColumnId   String?
  targetUserId String?
  createdAt    DateTime   @default(now())

  card       Card    @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user       User    @relation(fields: [userId], references: [id])
  fromColumn Column? @relation("FromColumn", fields: [fromColumnId], references: [id], onDelete: SetNull)
  toColumn   Column? @relation("ToColumn", fields: [toColumnId], references: [id], onDelete: SetNull)
  targetUser User?   @relation("ActivityTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
}

// ─── Label ────────────────────────────────────────────────────────────────────

model Label {
  id        String   @id @default(cuid())
  name      String
  color     String
  boardId   String
  createdAt DateTime @default(now())

  board Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards CardLabel[]
}

model CardLabel {
  cardId  String
  labelId String

  card  Card  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([cardId, labelId])
}
